<section class="section-card">
  <% if tracker_connection.errors.any? %>
    <div class="empty-state">
      <% tracker_connection.errors.full_messages.each do |message| %>
        <p><%= message %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: tracker_connection, url: url, method: method do |form| %>
    <div>
      <%= form.label :name %>
      <%= form.text_field :name %>
    </div>

    <div>
      <%= form.label :kind %>
      <%= form.text_field :kind %>
    </div>

    <div>
      <%= form.label :status %>
      <%= form.select :status, Symphony::TrackerConnection::STATUSES %>
    </div>

    <div>
      <%= form.label :config_json, "Config (JSON)" %>
      <%= form.text_area :config_json, value: tracker_connection.config.present? ? tracker_connection.config.to_json : "" %>
    </div>

    <%= form.submit submit_label %>
  <% end %>
</section>
