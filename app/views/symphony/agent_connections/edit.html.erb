<main class="app-shell">
  <section class="dashboard-shell">
    <header class="hero-card">
      <div class="hero-grid">
        <div>
          <p class="eyebrow">Symphony Admin</p>
          <h1 class="hero-title">Edit agent connection</h1>
          <p class="hero-copy">Update this managed agent connection.</p>
        </div>
      </div>
    </header>

    <%= render "form", agent_connection: @agent_connection, url: "/agent_connections/#{@agent_connection.id}", method: :patch, submit_label: "Update agent connection" %>
  </section>
</main>
