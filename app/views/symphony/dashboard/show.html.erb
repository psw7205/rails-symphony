<% content_for(:title, "Symphony Dashboard") %>
<% content_for(:head) do %>
  <%= stylesheet_link_tag "symphony/dashboard", "data-turbo-track": "reload" %>
<% end %>

<main class="app-shell" data-controller="dashboard" data-dashboard-interval-value="5000">
  <section class="dashboard-shell">
    <header class="hero-card">
      <div class="hero-grid">
        <div>
          <p class="eyebrow">Symphony Observability</p>
          <h1 class="hero-title">Operations Dashboard</h1>
          <p class="hero-copy">
            Current state, retry pressure, token usage, and orchestration health for the active Symphony runtime.
          </p>
        </div>
        <div class="status-stack">
          <span class="status-badge status-badge-live">
            <span class="status-badge-dot"></span>
            Live
          </span>
        </div>
      </div>
    </header>

    <section class="metric-grid">
      <article class="metric-card">
        <p class="metric-label">Projects</p>
        <p class="metric-value numeric"><%= @console_snapshot[:project_count] %></p>
        <p class="metric-detail">Managed projects currently configured in the admin console.</p>
      </article>

      <article class="metric-card">
        <p class="metric-label">Active workflows</p>
        <p class="metric-value numeric"><%= @console_snapshot[:active_workflow_count] %></p>
        <p class="metric-detail">Managed workflows currently participating in the console snapshot.</p>
      </article>

      <article class="metric-card">
        <p class="metric-label">Running</p>
        <p class="metric-value numeric"><%= @console_snapshot[:totals][:running] %></p>
        <p class="metric-detail">Active issue sessions across managed workflows.</p>
      </article>

      <article class="metric-card">
        <p class="metric-label">Retrying</p>
        <p class="metric-value numeric"><%= @console_snapshot[:totals][:retrying] %></p>
        <p class="metric-detail">Issues waiting for retry across managed workflows.</p>
      </article>

      <article class="metric-card">
        <p class="metric-label">Total tokens</p>
        <p class="metric-value numeric"><%= number_with_delimiter(@console_snapshot[:codex_totals][:total_tokens]) %></p>
        <p class="metric-detail numeric">
          In <%= number_with_delimiter(@console_snapshot[:codex_totals][:input_tokens]) %> /
          Out <%= number_with_delimiter(@console_snapshot[:codex_totals][:output_tokens]) %>
        </p>
      </article>

      <article class="metric-card">
        <p class="metric-label">Runtime</p>
        <p class="metric-value numeric"><%= format_runtime(@console_snapshot[:codex_totals][:seconds_running]) %></p>
        <p class="metric-detail">Total Codex runtime across managed workflow sessions.</p>
      </article>
    </section>

    <section class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Rate limits</h2>
          <p class="section-copy">Latest upstream rate-limit snapshot, when available.</p>
        </div>
      </div>
      <pre class="code-panel"><%= @console_snapshot[:rate_limits].presence&.to_json || "n/a" %></pre>
    </section>

    <section class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Managed workflows</h2>
          <p class="section-copy">Active managed workflows and their current runtime snapshot.</p>
        </div>
      </div>

      <% if @console_snapshot[:workflow_rows].empty? %>
        <p class="empty-state">No active workflows.</p>
      <% else %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Workflow</th>
                <th>Project</th>
                <th>Status</th>
                <th>Tracker</th>
                <th>Running</th>
                <th>Retrying</th>
              </tr>
            </thead>
            <tbody>
              <% @console_snapshot[:workflow_rows].each do |row| %>
                <% managed_workflow = row[:managed_workflow] %>
                <tr>
                  <td><%= managed_workflow.name %></td>
                  <td><%= managed_workflow.managed_project.name %></td>
                  <td><%= managed_workflow.status %></td>
                  <td><%= managed_workflow.tracker_connection.kind %></td>
                  <td><%= row[:snapshot][:counts][:running] %></td>
                  <td><%= row[:snapshot][:counts][:retrying] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>

    <section class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Running sessions</h2>
          <p class="section-copy">Active issues, last known agent activity, and token usage.</p>
        </div>
      </div>

      <% if @console_snapshot[:workflow_rows].empty? %>
        <p class="empty-state">No active workflows.</p>
      <% elsif @console_snapshot[:running].empty? %>
        <p class="empty-state">No active sessions.</p>
      <% else %>
        <div class="table-wrap">
          <table class="data-table data-table-running">
            <thead>
              <tr>
                <th>Issue</th>
                <th>State</th>
                <th>Runtime</th>
                <th>Last event</th>
              </tr>
            </thead>
            <tbody>
              <% @console_snapshot[:running].each do |entry| %>
                <tr>
                  <td>
                    <div class="issue-stack">
                      <span class="issue-id"><%= entry[:issue_identifier] %></span>
                      <%= link_to "JSON", api_v1_workflow_issue_path(entry[:managed_workflow_id], entry[:issue_identifier]), class: "issue-link" %>
                    </div>
                  </td>
                  <td><span class="state-badge <%= state_badge_class(entry[:state]) %>"><%= entry[:state] %></span></td>
                  <td class="numeric"><%= format_runtime(entry[:elapsed_seconds]) %></td>
                  <td><%= entry[:last_codex_event] || "n/a" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>

    <section class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Recent failures</h2>
          <p class="section-copy">Latest managed workflow failures waiting for operator attention.</p>
        </div>
      </div>

      <% if @console_snapshot[:recent_failures].empty? %>
        <p class="empty-state">No recent failures.</p>
      <% else %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Issue</th>
                <th>Attempt</th>
                <th>Error</th>
              </tr>
            </thead>
            <tbody>
              <% @console_snapshot[:recent_failures].each do |entry| %>
                <tr>
                  <td>
                    <div class="issue-stack">
                      <span class="issue-id"><%= entry[:issue_identifier] %></span>
                      <%= link_to "JSON", api_v1_workflow_issue_path(entry[:managed_workflow_id], entry[:issue_identifier]), class: "issue-link" %>
                    </div>
                  </td>
                  <td><%= entry[:attempt] %></td>
                  <td><%= entry[:error] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>

    <section class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Retry queue</h2>
          <p class="section-copy">Issues waiting for the next retry window.</p>
        </div>
      </div>

      <% if @console_snapshot[:workflow_rows].empty? %>
        <p class="empty-state">No active workflows.</p>
      <% elsif @console_snapshot[:retrying].empty? %>
        <p class="empty-state">No issues are currently backing off.</p>
      <% else %>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Issue</th>
                <th>Attempt</th>
                <th>Due at</th>
                <th>Error</th>
              </tr>
            </thead>
            <tbody>
              <% @console_snapshot[:retrying].each do |entry| %>
                <tr>
                  <td>
                    <div class="issue-stack">
                      <span class="issue-id"><%= entry[:issue_identifier] %></span>
                      <%= link_to "JSON", api_v1_workflow_issue_path(entry[:managed_workflow_id], entry[:issue_identifier]), class: "issue-link" %>
                    </div>
                  </td>
                  <td><%= entry[:attempt] %></td>
                  <td class="mono"><%= entry[:due_at] || "n/a" %></td>
                  <td><%= entry[:error] || "n/a" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% end %>
    </section>
  </section>
</main>
